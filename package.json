{
  "name": "nexql",
  "private": true,
  "version": "1.0.0",
  "description": "NexQL - Universal SQL database management platform for VS Code",
  "workspaces": [
    "packages/core",
    "packages/ext-postgres",
    "packages/ext-mysql",
    "packages/ext-sqlite",
    "packages/ext-mssql",
    "packages/ext-oracle"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
