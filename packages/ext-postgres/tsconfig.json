{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "paths": {
      "@nexql/core/*": ["../core/src/*"]
    },
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
