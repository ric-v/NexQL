{
  "buildCommand": "npm run build:site",
  "outputDirectory": "dist",
  "functions": {
    "api/config.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/create-subscription.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/verify-payment.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/cancel-subscription.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/auth/[...route].js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/sync/[...path].js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/license/[...route].js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
